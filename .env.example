# ============================================================
#  OZONE WASH BACKEND — Environment Variables
#  Copy this file to .env and fill in the values.
#  Lines starting with # are comments/instructions.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production         # change to "development" locally
APP_URL=https://api.ozonewash.in   # your deployed backend URL (no trailing slash)
                                    # Dev: http://YOUR_PC_IP:3000

# ── Database (Supabase PostgreSQL) ───────────────────────────
# Get from: supabase.com → Project → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# Get from: supabase.com → Project → Settings → API
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...    # "service_role" key — keep secret

# ── Auth (JWT) ───────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (only enforced in production)
ALLOWED_ORIGINS=https://admin.ozonewash.in,https://ozonewash.in

# ── Razorpay (Payments) ───────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
# Use "rzp_test_..." keys for testing, "rzp_live_..." for production
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# No keys? Backend falls back to mock orders in development automatically.

# ── Firebase (Push Notifications) ────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Service accounts
#           → Generate new private key → download JSON file
# Copy values from the JSON:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly (keep the \n escape sequences)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBAD...\n-----END PRIVATE KEY-----\n"
# No keys? Push notifications are skipped silently in development.

# ── SMS — OTP Delivery ────────────────────────────────────────
# Choose ONE provider. Default: fast2sms (cheapest, no DLT for testing)
SMS_PROVIDER=fast2sms     # options: fast2sms | msg91

# -- Fast2SMS (recommended for startups) --
# Signup: fast2sms.com → Dashboard → Dev API → copy API Key
# Cost: ~Rs.0.15/SMS. No DLT registration needed for testing.
SMS_API_KEY=your-fast2sms-api-key
SMS_SENDER_ID=OZNWSH
# DLT Template ID (required for production DLT compliance in India)
# Register template at: fast2sms.com → DLT → Templates
SMS_TEMPLATE_ID=your-approved-dlt-template-id

# -- MSG91 (enterprise, DLT compliant) --
# Signup: msg91.com → API → Auth Key
# Set SMS_PROVIDER=msg91 to use this instead
# SMS_API_KEY=your-msg91-authkey
# SMS_TEMPLATE_ID=your-msg91-flow-id
# No keys? OTP is logged to console in development automatically.

# ── WhatsApp (Wati) ───────────────────────────────────────────
# Get from: app.wati.io → Account → API → generate token
# WATI API URL depends on your server (check your wati.io dashboard)
WHATSAPP_API_KEY=your-wati-bearer-token
WHATSAPP_API_URL=https://live-mt-server.wati.io/api/v1
# Templates needed in WATI (create and get approved before going live):
#   otp_login, booking_confirmed, certificate_ready,
#   amc_renewal_reminder, payment_confirmed
# No keys? WhatsApp messages are logged to console in development automatically.

# ── Email (Gmail App Password) ────────────────────────────────
# Get from: Google Account → Security → 2-Step Verification → App Passwords
# Create app password for "Mail" → copy the 16-char password
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx     # 16-char Gmail app password (NOT your login password)
# No keys? Emails are logged to console in development automatically.

# ── Cloudflare R2 (Photo & Certificate Storage) ───────────────
# Get from: dash.cloudflare.com → R2 → your bucket → Manage R2 API Tokens
# Step 1: Create bucket named "ozone-wash-assets" in Cloudflare R2
# Step 2: Enable "Public access" on the bucket
# Step 3: Generate API token with "Object Read & Write" permission
R2_ACCOUNT_ID=your-cloudflare-account-id    # dash.cloudflare.com → right sidebar
R2_ACCESS_KEY=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=ozone-wash-assets
# Public URL — shown in bucket settings after enabling public access
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev
# No keys? Photos use placeholder local URLs in development automatically.
